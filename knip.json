{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.ts",
    "src/instrument.ts",
    "src/database/data-source.ts",
    "src/database/create-admin.ts",
    "src/database/migrate.ts",
    "src/database/seed.ts",
    "src/**/*.spec.ts",
    "scripts/**/*.ts",
    "scripts/**/*.js",
    "test/**/*.ts",
    "load-tests/**/*.js"
  ],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.{ts,js}",
    "test/**/*.ts",
    "load-tests/**/*.js"
  ],
  "ignore": [
    "src/database/migrations/**"
  ],
  "ignoreBinaries": ["k6"],
  "ignoreDependencies": ["k6", "express"],
  "ignoreIssues": {
    "**/dto/**": ["exports"],
    "**/constants/**": ["exports"],
    "src/common/decorators/**": ["exports"],
    "src/common/authorization/**": ["exports"],
    "src/common/constants/**": ["exports"],
    "src/common/dto/**": ["exports"],
    "src/common/entities/**": ["exports"],
    "src/common/guards/**": ["exports"],
    "src/common/i18n/index.ts": ["exports"],
    "src/common/interceptors/**": ["exports"],
    "src/common/telemetry/**": ["exports"],
    "src/common/utils/**": ["exports"],
    "src/config/index.ts": ["exports"],
    "src/database/**": ["exports"],
    "src/modules/**/decorators/**": ["exports"],
    "src/modules/tenants/guards/subscription.guard.ts": ["exports"],
    "src/modules/users/events/**": ["exports"]
  },
  "rules": {
    "exports": "error",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "namespaceMembers": "off"
  }
}
