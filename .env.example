# =============================================================================
# SOFTY ERP - Environment Configuration
# =============================================================================
# ⚠️ SECURITY WARNING:
# - NEVER commit .env files with real credentials to version control
# - For production, use secrets management (Vault, K8s Secrets, AWS Secrets Manager)
# - The values below are for LOCAL DEVELOPMENT only
# - See docker-compose.yml for related infrastructure configuration
# =============================================================================

# 🌍 Application Environment
NODE_ENV=development
PORT=3000
APP_NAME="Softy ERP"
COMPANY_NAME="Softy"
COMPANY_URL="https://erp.soft-y.org"

# 🧭 Reverse Proxy / Ingress
# ⚠️ IMPORTANT: Set to true when running behind nginx/ALB/ingress so the real client IP is
# read from X-Forwarded-For instead of the proxy's internal IP. Without this, all traffic
# from different users appears to come from a single IP and will share one rate-limit bucket,
# causing legitimate users to be blocked unexpectedly.
# Requires nginx to set: proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
TRUST_PROXY=false  # set to true in production behind a reverse proxy

# 🗄️ Database (PostgreSQL)
# ⚠️ PRODUCTION: Use secrets manager, not hardcoded values
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=chapters_studio
DB_PASSWORD=chapters_studio_secret
DB_DATABASE=chapters_studio
DB_SYNCHRONIZE=true   # ⚠️ Set to false in production - use migrations
DB_LOGGING=true

# 🗄️ Database Connection Pool (Tune for Production)
# DB_POOL_SIZE: Max connections (dev: 10-20, prod: 50-100 based on load)
DB_POOL_SIZE=20
# DB_CONNECTION_TIMEOUT: Connection acquisition timeout in ms (default: 30s)
DB_CONNECTION_TIMEOUT=30000
# DB_IDLE_TIMEOUT: Idle connection timeout in ms (default: 10min)
DB_IDLE_TIMEOUT=600000
# DB_STATEMENT_TIMEOUT: Max query execution time in ms (default: 60s)
DB_STATEMENT_TIMEOUT=60000

# 🗄️ Database Read Replicas (Optional - for high-availability)
# Comma-separated list of replica hosts (e.g., replica1.db.internal,replica2.db.internal)
# DB_REPLICA_HOSTS=
# DB_REPLICA_PORT=5432
# DB_REPLICA_USERNAME=
# DB_REPLICA_PASSWORD=

# 🔐 Authentication & Session Security

# JWT Algorithm Configuration
# - HS256: Uses JWT_SECRET for symmetric signing (development default)
# - RS256: Uses asymmetric keys (JWT_PUBLIC_KEY for verification, private key for signing in external service)
# Comma-separated list of allowed algorithms (e.g., HS256 or RS256 or HS256,RS256)
JWT_ALLOWED_ALGORITHMS=HS256

# HS256 Configuration (symmetric key)
# ⚠️ JWT_SECRET SECURITY REQUIREMENTS (Production):
#   - Minimum 43 characters (256 bits base64)
#   - Must contain both letters and numbers
#   - Must have high entropy (no repeated/sequential patterns)
#   - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Only required when HS256 is in JWT_ALLOWED_ALGORITHMS
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Dedicated platform admin JWT secret (must be different from JWT_SECRET)
PLATFORM_JWT_SECRET=your-platform-super-secret-jwt-key-change-in-production-min-32-chars

# RS256 Configuration (asymmetric keys)
# ⚠️ JWT_PUBLIC_KEY is REQUIRED when RS256 is in JWT_ALLOWED_ALGORITHMS
# Format: PEM-encoded RSA public key (use newlines as literal \n in the string, or base64 encode it)
# Example: -----BEGIN PUBLIC KEY-----\nMIIBIj...\n-----END PUBLIC KEY-----
# JWT_PUBLIC_KEY=

# 🔐 Cursor Pagination Security
# HMAC secret for signing cursor pagination tokens (prevents cursor manipulation)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# If not set, falls back to JWT_SECRET
CURSOR_SECRET=

# JWT Expiration Settings
JWT_ACCESS_EXPIRES_SECONDS=900
JWT_REFRESH_EXPIRES_DAYS=7

# 🛡️ Security Hardening - Account Lockout
# Brute-force protection limits
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=1800
LOCKOUT_WINDOW_SECONDS=900

# 🛡️ Security Hardening - MFA Enforcement
# Comma-separated roles that require MFA (e.g., ADMIN,OPS_MANAGER)
MFA_REQUIRED_ROLES=ADMIN

# 🛡️ Security Hardening - CORS
# Comma-separated allowed origins (enforced strictly in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

#  Data Encryption
# Encryption key for sensitive data at rest (e.g., API keys, tokens)
# ⚠️ PRODUCTION: REQUIRED - Must be at least 32 characters, cryptographically random
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
# Optional: Version identifier for key rotation (defaults to 'v1')
ENCRYPTION_KEY_VERSION=v1
# Optional: Previous encryption key for backward compatibility during key rotation
# ENCRYPTION_KEY_PREVIOUS=
# ENCRYPTION_KEY_PREVIOUS_VERSION=

# 📦 Object Storage (MinIO / S3)
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=softy-erp
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9000

# 📧 Email Service (SMTP)
MAIL_HOST=smtp.erp.soft-y.org
MAIL_PORT=587
MAIL_USER=noreply@erp.soft-y.org
MAIL_PASSWORD=your-mail-password
MAIL_FROM=Softy ERP <noreply@erp.soft-y.org>
MAIL_FROM_NAME=Softy ERP
MAIL_FROM_ADDRESS=noreply@erp.soft-y.org

# 📊 Telemetry & Observability
OTEL_ENABLED=true
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
SENTRY_DSN=

# Grafana Loki Log Aggregation (Optional)
# Set LOKI_HOST to enable log shipping to Grafana Loki
# LOKI_HOST=http://localhost:3100

# Prometheus metrics protection
# - In production, if METRICS_TOKEN is unset, the /api/v1/metrics endpoint returns 404.
# - If set, requests must send: Authorization: Bearer <METRICS_TOKEN>
METRICS_TOKEN=

# ⚡ Performance & Caching
REDIS_URL=redis://localhost:9379

# 🛠️ Maintenance & Backups
UPLOAD_TO_MINIO=true

# 🧪 Initial Seeding (Required for 'npm run seed')
# Do not commit real credentials. Set these locally.
SEED_ADMIN_PASSWORD=
SEED_STAFF_PASSWORD=
SEED_OPS_PASSWORD=
SEED_TENANT_NAME="Default Organization"
SEED_TENANT_SLUG="default-org"
SEED_EMAIL_DOMAIN="soft-y.org"

# 📋 Booking Configuration
MAX_TASKS_PER_BOOKING=500

# 🔑 HashiCorp Vault (Optional Secret Management)
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_SECRET_PATH=secret/data/softy-erp

# 🧪 Development & Testing Utilities
TEST_ERROR_KEY=some-random-key-for-errors
TEST_MOCK_PASSWORD="Test@Mock#Password!2024"
TEST_MOCK_PASSWORD_WRONG="Wrong@Mock#Password!2024"

# ⚠️ DISABLE_RATE_LIMITING=true # Use ONLY during heavy local testing/e2e

# 🚦 Rate Limiting (IpRateLimitGuard - applies globally to all endpoints)
# Tune these for your expected traffic. An ERP page load can fire 10-20 parallel API calls;
# with multiple concurrent office users sharing an IP the defaults must account for this.
# RATE_LIMIT_SOFT=200          # Requests before 429 starts (per IP per window)
# RATE_LIMIT_HARD=500          # Requests before IP is blocked entirely
# RATE_LIMIT_WINDOW_SECONDS=60 # Rolling window in seconds
# RATE_LIMIT_BLOCK_SECONDS=900 # How long a hard-blocked IP is locked out (15 min)

# 🚦 Throttler (@nestjs/throttler - applies to auth endpoints only)
# The 'short' profile (3 req/1s) is skipped on AuthController intentionally;
# per-endpoint @Throttle() limits already provide fine-grained control there.
# THROTTLE_SHORT_TTL_SECONDS=1
# THROTTLE_SHORT_LIMIT=3
# THROTTLE_MEDIUM_TTL_SECONDS=10
# THROTTLE_MEDIUM_LIMIT=20
# THROTTLE_LONG_TTL_SECONDS=60
# THROTTLE_LONG_LIMIT=100

# 💳 Stripe Billing (Optional - for subscription management)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
